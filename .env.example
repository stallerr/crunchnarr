# Required: signing secret for JWT auth tokens.
# Keep this stable across restarts — changing it invalidates every existing session.
# Generate one: openssl rand -base64 32
JWT_SECRET=change-me-to-a-random-secret

# Required: 32-byte AES-256-GCM key used to encrypt Widevine blobs and S3
# secrets at rest in the SQLite DB. Keep this stable — losing it means the
# encrypted blobs become unrecoverable.
# Generate one: openssl rand -hex 32
STORAGE_SECRET_KEY=

# API URL the browser sees (baked into the Next.js bundle at build time).
# Change this if you proxy the API behind a different hostname.
NEXT_PUBLIC_API_URL=http://localhost:8080

# API URL the Next.js server uses for SSR / auth-proxy calls.
# In a single-container deployment this is the same as NEXT_PUBLIC_API_URL.
# Set both if you split the API behind a separate ingress.
API_URL=http://localhost:8080

# Token TTLs (seconds)
ACCESS_TOKEN_TTL=3600
REFRESH_TOKEN_TTL=2592000

# Watchlist polling interval default (seconds). 3600 = hourly.
# Can also be overridden from Settings → Site in the web UI.
TRACKING_INTERVAL_SECS=3600

# Crunchyroll API request rate caps. Per-user (per linked CR account) +
# a global ceiling that aggregates across all users in this process.
# Defaults are conservative — raise carefully, CR has no public limit.
CRUNCHYROLL_RATE_LIMIT_RPS=3
CRUNCHYROLL_RATE_LIMIT_BURST=6
CRUNCHYROLL_RATE_LIMIT_GLOBAL_RPS=15
CRUNCHYROLL_RATE_LIMIT_GLOBAL_BURST=30

# Host paths interpolated by docker-compose for bind mounts (NOT read by
# the API server). The container always sees /downloads and /widevine;
# these set where those bind to on the host.
#
# Inside the container, the actual per-user output directory is
# controlled by the `output_dir` setting in Settings → Downloads, which
# should match the container mount point (default /downloads).
DOWNLOADS_DIR=./downloads

# Host path to your Widevine client_id.bin + private_key.pem.
# Crunchnarr does not ship a CDM — you supply your own.
# Mounted read-only into the container.
WIDEVINE_DIR=./widevine
